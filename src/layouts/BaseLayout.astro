---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noIndex?: boolean;
}

const { title, description, ...seoProps } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <SEO title={title} description={description} {...seoProps} />
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-screen bg-surface-base text-ink font-body">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
